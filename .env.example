## Docker Compose infrastructure defaults.
## Recovery runtime uses PostgreSQL/Flyway/RabbitMQ/Redis.
## Flyway uses the POSTGRES_* values below for schema bootstrap.

POSTGRES_DB=cfdi_vault
POSTGRES_USER=cfdi_vault
POSTGRES_PASSWORD=cfdi_vault
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=cfdi_vault
RABBITMQ_DEFAULT_PASS=cfdi_vault
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg://cfdi_vault:cfdi_vault@postgres:5432/cfdi_vault
RABBITMQ_URL=amqp://cfdi_vault:cfdi_vault@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0
CFDI_STORAGE_ROOT=/app/storage
